<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" - Tamandua EDR">
      <%= assigns[:page_title] || "Tamandua" %>
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={"/assets/#{TamanduaServerWeb.Vite.css_path()}"} />
    <script defer phx-track-static type="text/javascript" src={"/assets/#{TamanduaServerWeb.Vite.js_path()}"}>
    </script>
  </head>
  <body class="sentinel-theme antialiased" style="background: var(--bg); color: var(--fg);" data-theme={assigns[:theme] || "dark"}>
    <div
      id="product-status-banner"
      role="status"
      aria-label="Product validation status"
      class="w-full bg-amber-100 border-b border-amber-400 text-amber-900 dark:bg-amber-900/40 dark:border-amber-700 dark:text-amber-100 text-xs sm:text-sm px-4 py-1.5 flex items-center justify-center gap-2 font-medium"
      style="min-height: 28px;"
    >
      <span class="inline-flex items-center gap-1">
        <span aria-hidden="true">&#9888;</span>
        <strong><%= TamanduaServer.ProductStatus.status().label %></strong>
      </span>
      <span aria-hidden="true">&middot;</span>
      <span>Validation gate: <%= TamanduaServer.ProductStatus.gate_summary() %></span>
      <span aria-hidden="true">&middot;</span>
      <a
        href={TamanduaServer.ProductStatus.gaps_url()}
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:no-underline focus:outline-none focus:ring-1 focus:ring-amber-500 rounded"
      >
        View validation scope
      </a>
    </div>
    <%= @inner_content %>
  </body>
</html>
