{
  "name": "Executive Dashboard",
  "description": "High-level security posture overview with KPIs, compliance metrics, and geographic threat distribution",
  "template_category": "executive",
  "tags": ["executive", "kpi", "compliance", "metrics"],
  "author_name": "Tamandua EDR",
  "widgets": [
    {
      "type": "metric_card",
      "x": 0,
      "y": 0,
      "w": 3,
      "h": 2,
      "settings": {
        "title": "Active Threats",
        "metric": "active_threats_count",
        "icon": "shield-exclamation",
        "color": "red"
      }
    },
    {
      "type": "metric_card",
      "x": 3,
      "y": 0,
      "w": 3,
      "h": 2,
      "settings": {
        "title": "Compliance Score",
        "metric": "compliance_percentage",
        "icon": "clipboard-check",
        "color": "green"
      }
    },
    {
      "type": "metric_card",
      "x": 6,
      "y": 0,
      "w": 3,
      "h": 2,
      "settings": {
        "title": "Protected Assets",
        "metric": "protected_assets_count",
        "icon": "server-stack",
        "color": "blue"
      }
    },
    {
      "type": "metric_card",
      "x": 9,
      "y": 0,
      "w": 3,
      "h": 2,
      "settings": {
        "title": "SLA Compliance",
        "metric": "sla_compliance_percentage",
        "icon": "check-badge",
        "color": "green"
      }
    },
    {
      "type": "alert_trend",
      "x": 0,
      "y": 2,
      "w": 12,
      "h": 4,
      "settings": {
        "period": "30d",
        "groupBy": "day",
        "showSeverityBreakdown": true,
        "chartType": "area"
      }
    },
    {
      "type": "geo_map",
      "x": 0,
      "y": 6,
      "w": 12,
      "h": 5,
      "settings": {
        "showThreatDensity": true,
        "showAttackOrigins": true,
        "heatmapEnabled": true
      }
    },
    {
      "type": "sla_metrics",
      "x": 0,
      "y": 11,
      "w": 6,
      "h": 3,
      "settings": {
        "period": "30d",
        "showTrend": true,
        "highlightViolations": true
      }
    },
    {
      "type": "compliance_score",
      "x": 6,
      "y": 11,
      "w": 6,
      "h": 3,
      "settings": {
        "frameworks": ["SOC2", "ISO27001", "NIST"],
        "showBreakdown": true
      }
    }
  ],
  "settings": {
    "gridColumns": 12,
    "rowHeight": 60,
    "margins": [10, 10],
    "animate": true,
    "float": true
  }
}
